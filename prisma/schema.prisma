generator client {
  provider = "prisma-client-js"
  output = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  
}

model User {
  id         Int      @id @default(autoincrement())
  name       String  
  email      String   @unique
  password   String
  isVerified Boolean  @default(false)
  otp        String?
  otpExpiry  DateTime?
  createdAt DateTime  @default(now())
}
